generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  sessionId            String    @id @map("session_id")
  userId               String    @map("user_id")
  seq                  BigInt
  lastActivityAt       DateTime  @map("last_activity_at")
  lastUserText         String?   @map("last_user_text")
  topicDriftStreak     Int       @default(0) @map("topic_drift_streak")
  stickyProviderId     String?   @map("sticky_provider_id")
  stickyWeight         Decimal   @default(0.150) @map("sticky_weight") @db.Decimal(5, 3)
  switchLeadProviderId String?   @map("switch_lead_provider_id")
  switchLeadStreak     Int       @default(0) @map("switch_lead_streak")
  lastSwitchTs         DateTime? @map("last_switch_ts")
  topicState           Json?     @map("topic_state")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([userId], map: "idx_sessions_user_id")
  @@index([lastActivityAt], map: "idx_sessions_last_activity_at")
  @@map("sessions")
}

model TimelineEvent {
  eventId         String   @id @map("event_id")
  traceId         String   @map("trace_id")
  sessionId       String   @map("session_id")
  userId          String   @map("user_id")
  providerId      String?  @map("provider_id")
  runId           String?  @map("run_id")
  seq             BigInt
  timestampMs     BigInt   @map("timestamp_ms")
  kind            String
  extensionKind   String?  @map("extension_kind")
  renderSchemaRef String?  @map("render_schema_ref")
  payload         Json
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([sessionId, seq], map: "timeline_events_session_seq_key")
  @@index([sessionId, seq], map: "idx_timeline_events_session_seq")
  @@map("timeline_events")
}

model ProviderRun {
  runId          String   @id @map("run_id")
  traceId        String   @map("trace_id")
  sessionId      String   @map("session_id")
  userId         String   @map("user_id")
  providerId     String   @map("provider_id")
  mode           String
  routingMode    String   @map("routing_mode")
  idempotencyKey String   @map("idempotency_key")
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([sessionId], map: "idx_provider_runs_session_id")
  @@map("provider_runs")
}

model UserContextCache {
  profileRef   String   @id @map("profile_ref")
  userId       String   @map("user_id")
  snapshot     Json
  ttlExpiresAt DateTime @map("ttl_expires_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([ttlExpiresAt], map: "idx_user_context_cache_ttl")
  @@map("user_context_cache")
}

model OutboxEvent {
  id          BigInt    @id @default(autoincrement())
  eventId     String    @unique @map("event_id")
  sessionId   String    @map("session_id")
  channel     String    @default("timeline")
  payload     Json
  status      String    @default("pending")
  attempts    Int       @default(0)
  maxAttempts Int       @default(12) @map("max_attempts")
  lastError   String?   @map("last_error")
  nextRetryAt DateTime  @default(now()) @map("next_retry_at")
  lockedBy    String?   @map("locked_by")
  lockedAt    DateTime? @map("locked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  deliveredAt DateTime? @map("delivered_at")
  consumedAt  DateTime? @map("consumed_at")
  consumedBy  String?   @map("consumed_by")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt], map: "idx_outbox_events_status_created_at")
  @@index([status, nextRetryAt], map: "idx_outbox_events_status_next_retry")
  @@map("outbox_events")
}

model TaskThread {
  taskId           String   @map("task_id")
  sessionId        String   @map("session_id")
  providerId       String   @map("provider_id")
  runId            String   @map("run_id")
  state            String
  executionPolicy  String   @map("execution_policy")
  activeQuestionId String?  @map("active_question_id")
  activeReplyToken String?  @map("active_reply_token")
  metadata         Json?
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@id([sessionId, taskId], map: "task_threads_pkey")
  @@index([sessionId], map: "idx_task_threads_session_id")
  @@index([sessionId, state], map: "idx_task_threads_session_state")
  @@index([activeReplyToken], map: "idx_task_threads_active_reply_token")
  @@map("task_threads")
}

model WorkflowTemplate {
  workflowId  String   @id @map("workflow_id")
  workflowKey String   @unique @map("workflow_key")
  name        String
  status      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status], map: "idx_workflow_templates_status")
  @@map("workflow_templates")
}

model WorkflowTemplateVersion {
  templateVersionId String   @id @map("template_version_id")
  templateId        String   @map("template_id")
  version           Int
  status            String
  specJson          Json     @map("spec_json")
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([templateId, version], map: "workflow_template_versions_template_version_key")
  @@index([templateId, status], map: "idx_workflow_template_versions_template_status")
  @@map("workflow_template_versions")
}

model WorkflowDraft {
  draftId                     String   @id @map("draft_id")
  workflowKey                 String?  @map("workflow_key")
  name                        String?
  status                      String
  basedOnTemplateVersionId    String?  @map("based_on_template_version_id")
  publishedTemplateVersionId  String?  @map("published_template_version_id")
  currentSpecJson             Json     @map("current_spec_json")
  latestValidationSummaryJson Json?    @map("latest_validation_summary_json")
  publishable                 Boolean  @default(false)
  activeRevisionNumber        Int      @default(0) @map("active_revision_number")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@index([status], map: "idx_workflow_drafts_status")
  @@index([workflowKey], map: "idx_workflow_drafts_workflow_key")
  @@map("workflow_drafts")
}

model DraftRevision {
  revisionId            String   @id @map("revision_id")
  draftId               String   @map("draft_id")
  revisionNumber        Int      @map("revision_number")
  source                String
  actorId               String   @map("actor_id")
  changeSummary         String   @map("change_summary")
  specSnapshotJson      Json     @map("spec_snapshot_json")
  validationSummaryJson Json?    @map("validation_summary_json")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([draftId, revisionNumber], map: "draft_revisions_draft_revision_number_key")
  @@index([draftId, createdAt], map: "idx_draft_revisions_draft_created_at")
  @@map("draft_revisions")
}

model WorkflowDraftSessionLink {
  sessionId     String    @map("session_id")
  draftId       String    @map("draft_id")
  userId        String    @map("user_id")
  isActive      Boolean   @default(false) @map("is_active")
  lastFocusedAt DateTime? @map("last_focused_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@id([sessionId, draftId], map: "workflow_draft_session_links_pkey")
  @@index([sessionId, isActive], map: "idx_workflow_draft_session_links_session_active")
  @@index([draftId], map: "idx_workflow_draft_session_links_draft_id")
  @@map("workflow_draft_session_links")
}

model RecipeDraft {
  recipeDraftId       String   @id @map("recipe_draft_id")
  title               String?
  status              String
  sourceArtifactId    String?  @unique(map: "uq_recipe_drafts_source_artifact_id") @map("source_artifact_id")
  sourceRefsJson      Json     @map("source_refs_json")
  normalizedStepsJson Json     @map("normalized_steps_json")
  assumptionsJson     Json     @map("assumptions_json")
  reviewerNotesJson   Json     @map("reviewer_notes_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([status], map: "idx_recipe_drafts_status")
  @@map("recipe_drafts")
}

model WorkflowRun {
  runId             String    @id @map("run_id")
  templateId        String    @map("template_id")
  templateVersionId String    @map("template_version_id")
  agentId           String?   @map("agent_id")
  startMode         String    @default("debug_version") @map("start_mode")
  status            String
  sessionId         String    @map("session_id")
  userId            String    @map("user_id")
  currentNodeRunId  String?   @map("current_node_run_id")
  metadataJson      Json?     @map("metadata_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  completedAt       DateTime? @map("completed_at")

  @@index([sessionId], map: "idx_workflow_runs_session_id")
  @@index([templateId, status], map: "idx_workflow_runs_template_status")
  @@index([agentId], map: "idx_workflow_runs_agent_id")
  @@map("workflow_runs")
}

model WorkflowNodeRun {
  nodeRunId             String   @id @map("node_run_id")
  runId                 String   @map("run_id")
  nodeKey               String   @map("node_key")
  nodeType              String   @map("node_type")
  status                String
  executorId            String?  @map("executor_id")
  attempt               Int      @default(1)
  inputJson             Json?    @map("input_json")
  outputArtifactId      String?  @map("output_artifact_id")
  waitKey               String?  @map("wait_key")
  interactionRequestId  String?  @map("interaction_request_id")
  executionPolicy       String?  @map("execution_policy")
  metadataJson          Json?    @map("metadata_json")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([runId], map: "idx_workflow_node_runs_run_id")
  @@index([runId, status], map: "idx_workflow_node_runs_run_status")
  @@index([interactionRequestId], map: "idx_workflow_node_runs_interaction_request_id")
  @@map("workflow_node_runs")
}

model Artifact {
  artifactId   String   @id @map("artifact_id")
  runId        String   @map("run_id")
  nodeRunId    String?  @map("node_run_id")
  artifactType String   @map("artifact_type")
  state        String
  schemaRef    String?  @map("schema_ref")
  payloadJson  Json     @map("payload_json")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([runId], map: "idx_artifacts_run_id")
  @@index([nodeRunId], map: "idx_artifacts_node_run_id")
  @@map("artifacts")
}

model ApprovalRequest {
  approvalRequestId String    @id @map("approval_request_id")
  runId             String    @map("run_id")
  nodeRunId         String?   @map("node_run_id")
  artifactId        String?   @map("artifact_id")
  status            String
  requestedActorId  String?   @map("requested_actor_id")
  expiresAt         DateTime? @map("expires_at")
  payloadJson       Json?     @map("payload_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([runId], map: "idx_approval_requests_run_id")
  @@index([status], map: "idx_approval_requests_status")
  @@map("approval_requests")
}

model ApprovalDecision {
  approvalDecisionId String   @id @map("approval_decision_id")
  approvalRequestId  String   @map("approval_request_id")
  decision           String
  decidedActorId     String?  @map("decided_actor_id")
  comment            String?
  payloadJson        Json?    @map("payload_json")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([approvalRequestId], map: "idx_approval_decisions_request_id")
  @@map("approval_decisions")
}

model InteractionRequest {
  interactionRequestId String    @id @map("interaction_request_id")
  runId                String    @map("run_id")
  nodeRunId            String?   @map("node_run_id")
  status               String
  prompt               String
  answerSchemaJson     Json      @map("answer_schema_json")
  uiSchemaJson         Json      @map("ui_schema_json")
  payloadJson          Json?     @map("payload_json")
  responsePayloadJson  Json?     @map("response_payload_json")
  expiresAt            DateTime? @map("expires_at")
  respondedAt          DateTime? @map("responded_at")
  metadataJson         Json?     @map("metadata_json")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([runId], map: "idx_interaction_requests_run_id")
  @@index([status], map: "idx_interaction_requests_status")
  @@index([nodeRunId], map: "idx_interaction_requests_node_run_id")
  @@map("interaction_requests")
}

model AgentDefinition {
  agentId            String   @id @map("agent_id")
  workspaceId        String   @map("workspace_id")
  templateVersionRef String   @map("template_version_ref")
  name               String
  description        String?
  activationState    String   @map("activation_state")
  bridgeId           String?  @map("bridge_id")
  identityRef        String?  @map("identity_ref")
  executorStrategy   String   @map("executor_strategy")
  toolProfile        String?  @map("tool_profile")
  riskLevel          String?  @map("risk_level")
  ownerActorRef      String?  @map("owner_actor_ref")
  createdBy          String   @map("created_by")
  updatedBy          String   @map("updated_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, activationState], map: "idx_agent_definitions_workspace_state")
  @@index([templateVersionRef], map: "idx_agent_definitions_template_version_ref")
  @@index([bridgeId], map: "idx_agent_definitions_bridge_id")
  @@map("agent_definitions")
}

model BridgeRegistration {
  bridgeId           String    @id @map("bridge_id")
  workspaceId        String    @map("workspace_id")
  name               String
  description        String?
  baseUrl            String    @map("base_url")
  serviceId          String    @map("service_id")
  status             String
  runtimeType        String    @map("runtime_type")
  manifestJson       Json      @map("manifest_json")
  healthJson         Json?     @map("health_json")
  authConfigJson     Json      @map("auth_config_json")
  callbackConfigJson Json      @map("callback_config_json")
  lastHealthAt       DateTime? @map("last_health_at")
  createdBy          String    @map("created_by")
  updatedBy          String    @map("updated_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId, status], map: "idx_bridge_registrations_workspace_status")
  @@index([serviceId], map: "idx_bridge_registrations_service_id")
  @@map("bridge_registrations")
}

model TriggerBinding {
  triggerBindingId String    @id @map("trigger_binding_id")
  workspaceId      String    @map("workspace_id")
  agentId          String    @map("agent_id")
  triggerKind      String    @map("trigger_kind")
  status           String
  configJson       Json      @map("config_json")
  publicTriggerKey String?   @unique(map: "uq_trigger_bindings_public_trigger_key") @map("public_trigger_key")
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  nextTriggerAt    DateTime? @map("next_trigger_at")
  lastError        String?   @map("last_error")
  createdBy        String    @map("created_by")
  updatedBy        String    @map("updated_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([agentId, status], map: "idx_trigger_bindings_agent_status")
  @@index([triggerKind, status, nextTriggerAt], map: "idx_trigger_bindings_kind_status_next_trigger")
  @@map("trigger_bindings")
}

model ConnectorDefinition {
  connectorDefinitionId String   @id @map("connector_definition_id")
  workspaceId           String   @map("workspace_id")
  connectorKey          String   @map("connector_key")
  name                  String
  description           String?
  status                String
  catalogJson           Json     @map("catalog_json")
  createdBy             String   @map("created_by")
  updatedBy             String   @map("updated_by")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, connectorKey], map: "uq_connector_definitions_workspace_key")
  @@index([workspaceId, status], map: "idx_connector_definitions_workspace_status")
  @@map("connector_definitions")
}

model ConnectorBinding {
  connectorBindingId   String   @id @map("connector_binding_id")
  workspaceId          String   @map("workspace_id")
  connectorDefinitionId String  @map("connector_definition_id")
  name                 String
  description          String?
  status               String
  secretRefId          String?  @map("secret_ref_id")
  metadataJson         Json?    @map("metadata_json")
  createdBy            String   @map("created_by")
  updatedBy            String   @map("updated_by")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, status], map: "idx_connector_bindings_workspace_status")
  @@index([connectorDefinitionId], map: "idx_connector_bindings_definition_id")
  @@index([secretRefId], map: "idx_connector_bindings_secret_ref_id")
  @@map("connector_bindings")
}

model ActionBinding {
  actionBindingId     String   @id @map("action_binding_id")
  workspaceId         String   @map("workspace_id")
  agentId             String   @map("agent_id")
  actionRef           String   @map("action_ref")
  connectorBindingId  String   @map("connector_binding_id")
  capabilityId        String   @map("capability_id")
  status              String
  sideEffectClass     String   @map("side_effect_class")
  executionMode       String   @map("execution_mode")
  timeoutMs           Int?     @map("timeout_ms")
  browserFallbackMode String   @map("browser_fallback_mode")
  configJson          Json     @map("config_json")
  createdBy           String   @map("created_by")
  updatedBy           String   @map("updated_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([agentId, actionRef], map: "uq_action_bindings_agent_action_ref")
  @@index([workspaceId, status], map: "idx_action_bindings_workspace_status")
  @@index([connectorBindingId], map: "idx_action_bindings_binding_id")
  @@map("action_bindings")
}

model EventSubscription {
  eventSubscriptionId String    @id @map("event_subscription_id")
  workspaceId         String    @map("workspace_id")
  connectorBindingId  String    @map("connector_binding_id")
  triggerBindingId    String    @map("trigger_binding_id")
  eventType           String    @map("event_type")
  status              String
  publicSubscriptionKey String? @unique(map: "uq_event_subscriptions_public_subscription_key") @map("public_subscription_key")
  configJson          Json      @map("config_json")
  lastEventAt         DateTime? @map("last_event_at")
  lastError           String?   @map("last_error")
  createdBy           String    @map("created_by")
  updatedBy           String    @map("updated_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId, status], map: "idx_event_subscriptions_workspace_status")
  @@index([connectorBindingId], map: "idx_event_subscriptions_binding_id")
  @@index([triggerBindingId], map: "idx_event_subscriptions_trigger_binding_id")
  @@map("event_subscriptions")
}

model PolicyBinding {
  policyBindingId String   @id @map("policy_binding_id")
  workspaceId     String   @map("workspace_id")
  policyKind      String   @map("policy_kind")
  targetType      String   @map("target_type")
  targetRef       String   @map("target_ref")
  status          String
  configJson      Json     @map("config_json")
  createdBy       String   @map("created_by")
  updatedBy       String   @map("updated_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([targetType, targetRef], map: "idx_policy_bindings_target")
  @@index([workspaceId, status], map: "idx_policy_bindings_workspace_status")
  @@map("policy_bindings")
}

model SecretRef {
  secretRefId      String   @id @map("secret_ref_id")
  workspaceId      String   @map("workspace_id")
  environmentScope String   @map("environment_scope")
  providerType     String   @map("provider_type")
  status           String
  metadataJson     Json     @map("metadata_json")
  createdBy        String   @map("created_by")
  updatedBy        String   @map("updated_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, status], map: "idx_secret_refs_workspace_status")
  @@index([providerType], map: "idx_secret_refs_provider_type")
  @@map("secret_refs")
}

model ScopeGrant {
  scopeGrantId String    @id @map("scope_grant_id")
  workspaceId  String    @map("workspace_id")
  targetType   String    @map("target_type")
  targetRef    String    @map("target_ref")
  resourceType String    @map("resource_type")
  resourceRef  String    @map("resource_ref")
  status       String
  scopeJson    Json      @map("scope_json")
  expiresAt    DateTime? @map("expires_at")
  createdBy    String    @map("created_by")
  updatedBy    String    @map("updated_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([targetType, targetRef], map: "idx_scope_grants_target")
  @@index([resourceType, resourceRef], map: "idx_scope_grants_resource")
  @@index([workspaceId, status], map: "idx_scope_grants_workspace_status")
  @@map("scope_grants")
}

model GovernanceChangeRequest {
  requestId          String   @id @map("request_id")
  workspaceId        String   @map("workspace_id")
  requestKind        String   @map("request_kind")
  targetType         String   @map("target_type")
  targetRef          String   @map("target_ref")
  requestedByActorId String   @map("requested_by_actor_id")
  status             String
  riskLevel          String   @map("risk_level")
  summary            String
  justification      String?
  desiredStateJson   Json     @map("desired_state_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, status], map: "idx_governance_change_requests_workspace_status")
  @@index([targetType, targetRef], map: "idx_governance_change_requests_target")
  @@map("governance_change_requests")
}

model GovernanceChangeDecision {
  decisionId String   @id @map("decision_id")
  requestId  String   @map("request_id")
  actorRef   String   @map("actor_ref")
  decision   String
  comment    String?
  decidedAt  DateTime @map("decided_at")

  @@index([requestId], map: "idx_governance_change_decisions_request_id")
  @@map("governance_change_decisions")
}

model TriggerDispatch {
  triggerDispatchId String   @id @map("trigger_dispatch_id")
  triggerBindingId  String   @map("trigger_binding_id")
  dispatchKey       String   @unique(map: "uq_trigger_dispatches_dispatch_key") @map("dispatch_key")
  sourceType        String   @map("source_type")
  status            String
  runId             String?  @map("run_id")
  payloadJson       Json?    @map("payload_json")
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([triggerBindingId, status], map: "idx_trigger_dispatches_binding_status")
  @@map("trigger_dispatches")
}

model BridgeInvokeSession {
  bridgeSessionId    String    @id @map("bridge_session_id")
  runId              String    @map("run_id")
  nodeRunId          String    @map("node_run_id")
  bridgeId           String    @map("bridge_id")
  externalSessionRef String    @map("external_session_ref")
  status             String
  lastSequence       Int       @default(0) @map("last_sequence")
  resumeToken        String?   @map("resume_token")
  cancelledAt        DateTime? @map("cancelled_at")
  metadataJson       Json?     @map("metadata_json")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([bridgeId, externalSessionRef], map: "uq_bridge_invoke_sessions_bridge_external_session")
  @@index([runId], map: "idx_bridge_invoke_sessions_run_id")
  @@index([nodeRunId], map: "idx_bridge_invoke_sessions_node_run_id")
  @@index([bridgeId, status], map: "idx_bridge_invoke_sessions_bridge_status")
  @@map("bridge_invoke_sessions")
}

