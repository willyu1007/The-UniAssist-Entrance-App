# =========================
# Shared baseline
# =========================
NODE_ENV=staging

# Persistence
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/uniassist_staging
REDIS_URL=redis://<host>:6379

# K8s overlay reminder:
# - ops/deploy/k8s/overlays/staging/secret-staging.patch.yaml should be replaced by
#   environment secret manager values before apply.

# Streams
UNIASSIST_STREAM_PREFIX=uniassist:timeline:
UNIASSIST_STREAM_GLOBAL_KEY=uniassist:timeline:all
UNIASSIST_STREAM_GROUP=ua-delivery-staging
UNIASSIST_STREAM_CONSUMER=ua-worker-staging

# Security
UNIASSIST_INTERNAL_AUTH_MODE=audit
UNIASSIST_INTERNAL_AUTH_ISSUER=uniassist-internal
UNIASSIST_INTERNAL_AUTH_KEYS_JSON={"kid-main":"<replace-with-strong-secret>"}
UNIASSIST_INTERNAL_AUTH_SIGNING_KID=kid-main
UNIASSIST_INTERNAL_AUTH_TOKEN_TTL_S=300
UNIASSIST_INTERNAL_AUTH_CLOCK_SKEW_S=120
UNIASSIST_INTERNAL_AUTH_NONCE_TTL_S=300
UNIASSIST_INTERNAL_AUTH_REPLAY_BACKEND=redis

# Service wiring
VITE_WORKFLOW_PLATFORM_API_BASE_URL=https://workflow-platform-api.staging.example.com
UNIASSIST_WORKFLOW_PLATFORM_API_BASE_URL=http://workflow-platform-api:8791
UNIASSIST_WORKFLOW_PLATFORM_BASE_URL=http://workflow-platform-api:8791
UNIASSIST_WORKFLOW_RUNTIME_BASE_URL=http://workflow-runtime:8792
UNIASSIST_WORKFLOW_RUNTIME_PUBLIC_BASE_URL=https://workflow-runtime.staging.example.com
UNIASSIST_CONNECTOR_RUNTIME_BASE_URL=http://connector-runtime:8895
UNIASSIST_EXTERNAL_BRIDGE_ALLOWED_SUBJECTS=executor-bridge-sample
UNIASSIST_TRIGGER_SCHEDULER_POLL_INTERVAL_MS=5000

# =========================
# Worker tuning
# =========================
OUTBOX_POLL_MS=1000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=12
OUTBOX_BACKOFF_BASE_MS=1000
OUTBOX_BACKOFF_MAX_MS=300000
STREAM_CONSUMER_BLOCK_MS=2000
STREAM_CONSUMER_BATCH_SIZE=100

# =========================
# Post-deploy verification
# =========================
STAGING_CONTROL_CONSOLE_BASE_URL=https://control-console.staging.example.com
STAGING_WORKFLOW_PLATFORM_API_BASE_URL=https://workflow-platform-api.staging.example.com
STAGING_WORKFLOW_RUNTIME_BASE_URL=https://workflow-runtime.staging.example.com
STAGING_CONNECTOR_RUNTIME_BASE_URL=https://connector-runtime.staging.example.com
STAGING_TRIGGER_SCHEDULER_BASE_URL=https://trigger-scheduler.staging.example.com
STAGING_VERIFY_TIMEOUT_MS=30000

# =========================
# Worker reliability drill
# =========================
WORKER_DRILL_MODE=simulate
WORKER_DRILL_TIMEOUT_MS=45000
WORKER_DRILL_ENABLE_NOGROUP=true
WORKER_DRILL_OUTPUT_PATH=ops/deploy/reports/staging-worker-drill-latest.md

# =========================
# Observability drill
# =========================
DRILL_MODE=simulate
DRILL_OUTPUT_PATH=ops/observability/reports/staging-drill-latest.md
STAGING_WORKER_STATUS=healthy
