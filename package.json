{
  "name": "baseinterface-appmain",
  "version": "0.1.0",
  "description": "Cross-platform mobile app template homepage SOT for reusable UI components and multimodal editing entry.",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.mjs",
    "dev": "pnpm --filter @baseinterface/frontend start",
    "dev:gateway": "pnpm --filter @baseinterface/gateway start",
    "dev:wechat": "pnpm --filter @baseinterface/adapter-wechat start",
    "dev:provider-sample": "pnpm --filter @baseinterface/provider-sample start",
    "dev:executor-bridge-sample": "pnpm --filter @baseinterface/executor-bridge-sample start",
    "dev:workflow-platform-api": "pnpm --filter @baseinterface/workflow-platform-api start",
    "dev:workflow-runtime": "pnpm --filter @baseinterface/workflow-runtime start",
    "dev:trigger-scheduler": "pnpm --filter @baseinterface/trigger-scheduler start",
    "dev:control-console": "pnpm --filter @baseinterface/control-console dev",
    "dev:worker": "pnpm --filter @baseinterface/worker start",
    "smoke:redis:e2e": "pnpm --filter @baseinterface/worker smoke:redis:e2e",
    "worker:replay:dead-letter": "pnpm --filter @baseinterface/worker replay:dead-letter",
    "observability:alerts:validate": "node ops/observability/scripts/validate-alert-rules.mjs",
    "observability:drill:staging": "node ops/observability/scripts/staging-alert-drill.mjs",
    "worker:drill:staging": "node ops/deploy/scripts/staging-worker-reliability-drill.mjs",
    "release:gate:staging": "node ops/deploy/scripts/staging-release-gate.mjs",
    "release:verify:staging": "node ops/deploy/scripts/staging-post-deploy-check.mjs",
    "k8s:kind:up": "node ops/deploy/scripts/k8s-kind-up.mjs",
    "k8s:kind:down": "node ops/deploy/scripts/k8s-kind-down.mjs",
    "k8s:staging:validate": "node ops/deploy/scripts/k8s-staging-validate.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:workspaces": "pnpm -r --if-present typecheck",
    "db:sync-context": "node .ai/scripts/ctl-db-ssot.mjs sync-to-context",
    "test:conformance": "pnpm --filter @baseinterface/gateway test:conformance",
    "test:workflow-entry": "pnpm --filter @baseinterface/gateway test:workflow-entry"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prisma": "6.16.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10 <11"
  }
}
