{
  "name": "uniassist-workflow-platform",
  "version": "0.1.0",
  "description": "UniAssist pure-v1 workflow platform for agent-driven custom workflows.",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.mjs",
    "dev": "pnpm --filter @uniassist/control-console dev",
    "dev:executor-bridge-sample": "pnpm --filter @uniassist/executor-bridge-sample start",
    "dev:connector-runtime": "pnpm --filter @uniassist/connector-runtime start",
    "dev:workflow-platform-api": "pnpm --filter @uniassist/workflow-platform-api start",
    "dev:workflow-runtime": "pnpm --filter @uniassist/workflow-runtime start",
    "dev:trigger-scheduler": "pnpm --filter @uniassist/trigger-scheduler start",
    "dev:control-console": "pnpm --filter @uniassist/control-console dev",
    "dev:worker": "pnpm --filter @uniassist/worker start",
    "smoke:pure-v1": "pnpm --filter @uniassist/workflow-runtime test && pnpm --filter @uniassist/workflow-platform-api test && pnpm --filter @uniassist/control-console test && pnpm --filter @uniassist/worker test",
    "worker:replay:dead-letter": "pnpm --filter @uniassist/worker replay:dead-letter",
    "observability:alerts:validate": "node ops/observability/scripts/validate-alert-rules.mjs",
    "observability:drill:staging": "node ops/observability/scripts/staging-alert-drill.mjs",
    "worker:drill:staging": "node ops/deploy/scripts/staging-worker-reliability-drill.mjs",
    "release:gate:staging": "node ops/deploy/scripts/staging-release-gate.mjs",
    "release:verify:staging": "node ops/deploy/scripts/staging-post-deploy-check.mjs",
    "k8s:kind:up": "node ops/deploy/scripts/k8s-kind-up.mjs",
    "k8s:kind:down": "node ops/deploy/scripts/k8s-kind-down.mjs",
    "k8s:staging:validate": "node ops/deploy/scripts/k8s-staging-validate.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:workspaces": "pnpm -r --if-present typecheck",
    "db:sync-context": "node .ai/scripts/ctl-db-ssot.mjs sync-to-context"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prisma": "6.16.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10 <11"
  }
}
