{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2022"],
    "strict": true,
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@baseinterface/connector-ci-pipeline-sample": ["apps/connectors/ci-pipeline-sample/src/index.ts"],
      "@baseinterface/connector-issue-tracker-sample": ["apps/connectors/issue-tracker-sample/src/index.ts"],
      "@baseinterface/connector-sdk": ["packages/connector-sdk/src/index.ts"],
      "@baseinterface/contracts": ["packages/contracts/src/index.ts"],
      "@baseinterface/convex-projection-experiment": ["packages/convex-projection-experiment/src/index.ts"],
      "@baseinterface/executor-sdk": ["packages/executor-sdk/src/index.ts"],
      "@baseinterface/policy-sdk": ["packages/policy-sdk/src/index.ts"],
      "@baseinterface/shared": ["packages/shared/src/index.ts"],
      "@baseinterface/workflow-contracts": ["packages/workflow-contracts/src/index.ts"]
    },
    "noEmit": true,
    "isolatedModules": true
  },
  "references": [
    { "path": "apps/frontend" }
  ],
  "files": [],
  "exclude": ["node_modules"]
}
